{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./src",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@app/*": ["./*"],
      "@common/*": ["./common/*"],
      "@finance/*": ["./finance/*"],
      "@auth/*": ["./auth/*"],
      "@analytics/*": ["./analytics/*"]
    }
  }
}
